<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:FreshTrack.Controls"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="FreshTrack.GroceryListDetailPage"
             Title="List Detail"
             Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F2FBF4" Offset="0" />
            <GradientStop Color="#DCF4E2" Offset="1" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="PanelCardStyle" TargetType="Border">
                <Setter Property="Stroke" Value="#B8DEC1" />
                <Setter Property="StrokeThickness" Value="1.5" />
                <Setter Property="BackgroundColor" Value="#FCFFFC" />
                <Setter Property="Padding" Value="18,16" />
                <Setter Property="WidthRequest" Value="300" />
            </Style>

            <Style x:Key="SectionEditorStyle" TargetType="Editor">
                <Setter Property="AutoSize" Value="TextChanges" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="#355342" />
                <Setter Property="PlaceholderColor" Value="#8CA494" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="Margin" Value="0,10,0,0" />
            </Style>

            <Style x:Key="ActionButtonStyle" TargetType="controls:AnimatedButton">
                <Setter Property="HeightRequest" Value="56" />
                <Setter Property="CornerRadius" Value="24" />
                <Setter Property="Padding" Value="20,10" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <Style x:Key="PrimaryActionButtonStyle" TargetType="controls:AnimatedButton" BasedOn="{StaticResource ActionButtonStyle}">
                <Setter Property="BackgroundColor" Value="#3FA36C" />
                <Setter Property="BorderColor" Value="#3FA36C" />
                <Setter Property="TextColor" Value="White" />
            </Style>

            <Style x:Key="SecondaryActionButtonStyle" TargetType="controls:AnimatedButton" BasedOn="{StaticResource ActionButtonStyle}">
                <Setter Property="BackgroundColor" Value="#F6FFF8" />
                <Setter Property="BorderColor" Value="#9AC9A8" />
                <Setter Property="BorderWidth" Value="1.5" />
                <Setter Property="TextColor" Value="#3D6750" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,24,24,10"
                                 Spacing="16"
                                 HorizontalOptions="Center">
                <VerticalStackLayout Spacing="6"
                                     HorizontalOptions="Center"
                                     Margin="0,0,0,4">
                    <Label Text="Fresh List Detail"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#2E5B43"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Organize your grocery reminder in clear green sections."
                           FontSize="13"
                           TextColor="#6E8D7A"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <Border Style="{StaticResource PanelCardStyle}">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="26" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#154E6E3A" Offset="0,8" Radius="18" Opacity="0.14" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="List Title"
                               FontSize="13"
                               TextColor="#70907A" />
                        <Entry x:Name="NameEntry"
                               Placeholder="Enter a short list title"
                               HeightRequest="48"
                               BackgroundColor="#F2FAF3"
                               TextColor="#274734"
                               PlaceholderColor="#89A08F"
                               TextChanged="OnContentChanged" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource PanelCardStyle}">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="26" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Address"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="#2E5B43" />
                        <Editor x:Name="AddressEntry"
                                Style="{StaticResource SectionEditorStyle}"
                                AutoSize="Disabled"
                                HeightRequest="78"
                                Placeholder="Add the market, store, or delivery address here"
                                TextChanged="OnContentChanged" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource PanelCardStyle}">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="26" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Vegetables"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="#2E5B43" />
                        <Editor x:Name="VegetableEntry"
                                Style="{StaticResource SectionEditorStyle}"
                                Placeholder="Lettuce, tomatoes, cucumbers..."
                                TextChanged="OnContentChanged" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource PanelCardStyle}">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="26" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Meat"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="#2E5B43" />
                        <Editor x:Name="MeatEntry"
                                Style="{StaticResource SectionEditorStyle}"
                                Placeholder="Chicken, beef, fish..."
                                TextChanged="OnContentChanged" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource PanelCardStyle}">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="26" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Drinks"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="#2E5B43" />
                        <Editor x:Name="DrinkEntry"
                                Style="{StaticResource SectionEditorStyle}"
                                Placeholder="Milk, juice, sparkling water..."
                                TextChanged="OnContentChanged" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource PanelCardStyle}"
                        Margin="0,0,0,8">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="26" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Items"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="#2E5B43" />
                        <Editor x:Name="ItemEntry"
                                Style="{StaticResource SectionEditorStyle}"
                                Placeholder="Bags, paper towels, seasoning..."
                                TextChanged="OnContentChanged" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource PanelCardStyle}"
                        Margin="0,0,0,8">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="26" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Reminder Schedule"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="#2E5B43" />
                        <Label Text="Choose the exact date and time for this reminder."
                               FontSize="13"
                               TextColor="#6E8D7A" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Date"
                                       FontSize="13"
                                       TextColor="#70907A" />
                                <Border Stroke="#B8DEC1"
                                        StrokeThickness="1"
                                        BackgroundColor="#F2FAF3"
                                        Padding="14,12">
                                    <Border.StrokeShape>
                                        <shapes:RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>
                                    <Label x:Name="ReminderDateDisplayLabel"
                                           Text="Not set"
                                           FontSize="14"
                                           TextColor="#274734" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="6">
                                <Label Text="Time"
                                       FontSize="13"
                                       TextColor="#70907A" />
                                <Border Stroke="#B8DEC1"
                                        StrokeThickness="1"
                                        BackgroundColor="#F2FAF3"
                                        Padding="14,12">
                                    <Border.StrokeShape>
                                        <shapes:RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>
                                    <Label x:Name="ReminderTimeDisplayLabel"
                                           Text="--:--"
                                           FontSize="14"
                                           TextColor="#274734" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <Label x:Name="ReminderStatusLabel"
                               Text="Tap Reminder to change the schedule."
                               FontSize="12"
                               TextColor="#70907A" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="14"
              Padding="20,12,20,20">
            <controls:AnimatedButton x:Name="BackButton"
                                     Text="Back"
                                     Clicked="OnBackClicked"
                                     HorizontalOptions="Start"
                                     Style="{StaticResource SecondaryActionButtonStyle}" />

            <controls:AnimatedButton Grid.Column="1"
                                     Text="Reminder"
                                     Clicked="OnClockClicked"
                                     HorizontalOptions="Center"
                                     Style="{StaticResource SecondaryActionButtonStyle}" />

            <controls:AnimatedButton x:Name="SaveButton"
                                     Grid.Column="2"
                                     Text="Save"
                                     Clicked="OnSaveClicked"
                                     HorizontalOptions="End"
                                     IsVisible="False"
                                     IsEnabled="False"
                                     Style="{StaticResource PrimaryActionButtonStyle}" />
        </Grid>

        <Grid x:Name="ReminderSelectionOverlay"
              Grid.RowSpan="2"
              BackgroundColor="#66000000"
              IsVisible="False"
              Padding="24">
            <Border WidthRequest="320"
                    MaximumWidthRequest="360"
                    BackgroundColor="#FCFFFC"
                    Stroke="#B8DEC1"
                    StrokeThickness="1.5"
                    Padding="20,18"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <shapes:RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Set Reminder"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#2E5B43" />
                        <Label Text="Choose the date and time, then tap Apply."
                               FontSize="13"
                               TextColor="#6E8D7A" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Date"
                                   FontSize="13"
                                   TextColor="#70907A" />
                            <DatePicker x:Name="ReminderDatePicker"
                                        BackgroundColor="#F2FAF3"
                                        Format="yyyy-MM-dd"
                                        TextColor="#274734" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="6">
                            <Label Text="Time"
                                   FontSize="13"
                                   TextColor="#70907A" />
                            <TimePicker x:Name="ReminderTimePicker"
                                        BackgroundColor="#F2FAF3"
                                        Format="HH:mm"
                                        TextColor="#274734" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <controls:AnimatedButton Text="Cancel"
                                                 Clicked="OnReminderCancelClicked"
                                                 Style="{StaticResource SecondaryActionButtonStyle}" />

                        <controls:AnimatedButton Grid.Column="1"
                                                 Text="Apply"
                                                 Clicked="OnReminderApplyClicked"
                                                 Style="{StaticResource PrimaryActionButtonStyle}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
