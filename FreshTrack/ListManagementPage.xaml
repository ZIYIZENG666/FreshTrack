<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:controls="clr-namespace:FreshTrack.Controls"
             x:Class="FreshTrack.ListManagementPage"
             x:Name="RootPage"
             Title="List Management"
             Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F0FBF3" Offset="0" />
            <GradientStop Color="#D9F2E0" Offset="1" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="PillButtonStyle" TargetType="controls:AnimatedButton">
                <Setter Property="WidthRequest" Value="220" />
                <Setter Property="HeightRequest" Value="56" />
                <Setter Property="CornerRadius" Value="28" />
                <Setter Property="BackgroundColor" Value="#F9FFF9" />
                <Setter Property="BorderColor" Value="#ABD2B7" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="Padding" Value="16,8" />
                <Setter Property="TextColor" Value="#35604A" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="20" RowDefinitions="Auto,*,Auto">
        <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,4,0,12">
            <Label Text="List Management"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#2E5B43" />
            <Label Text="Tap a list card to view or edit its details."
                   FontSize="13"
                   TextColor="#6E8D7A" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        x:Name="ListcollectionView"
                        ItemsSource="{Binding Lists}"
                        SelectionMode="None"
                        Margin="0,2,0,0"
                        ItemSizingStrategy="MeasureAllItems">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
            </CollectionView.ItemsLayout>

            <CollectionView.EmptyView>
                <Border Stroke="#B9DDC4"
                        StrokeThickness="1"
                        Padding="20">
                    <Border.StrokeShape>
                        <shapes:RoundRectangle CornerRadius="22" />
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush EndPoint="1,1">
                            <GradientStop Color="#FDFFFD" Offset="0" />
                            <GradientStop Color="#F1FAF2" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Label Text="No grocery lists yet. Add one to get started."
                           HorizontalTextAlignment="Center"
                           TextColor="#6E8D7A"
                           FontSize="14" />
                </Border>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Padding="0,2">
                        <Border Grid.Column="0"
                                Stroke="#B8DEC1"
                                StrokeThickness="1"
                                Padding="16,14"
                                MinimumHeightRequest="84">
                            <Border.StrokeShape>
                                <shapes:RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush EndPoint="1,1">
                                    <GradientStop Color="#FDFFFD" Offset="0" />
                                    <GradientStop Color="#EEF9F0" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Shadow>
                                <Shadow Brush="#1C4C7A55" Offset="0,8" Radius="18" Opacity="0.16" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnListTapped"
                                                      CommandParameter="{Binding}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                <Border WidthRequest="42"
                                        HeightRequest="42"
                                        Stroke="#C6DCCA"
                                        StrokeThickness="1.5"
                                        BackgroundColor="#F9FFF9"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <shapes:RoundRectangle CornerRadius="21" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#16000000" Offset="0,3" Radius="8" Opacity="0.1" />
                                    </Border.Shadow>
                                    <Label Text="{Binding BadgeText}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#4F7A62" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="4"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#2F5B42"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1" />
                                    <Label Text="{Binding CardTimestamp}"
                                           FontSize="12"
                                           TextColor="#7F9A87" />
                                </VerticalStackLayout>

                                <Label Grid.Column="2"
                                       Text=">"
                                       FontSize="22"
                                       TextColor="#679072"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <controls:AnimatedButton Grid.Column="1"
                                                 Text="X"
                                                 FontSize="18"
                                                 FontAttributes="Bold"
                                                 TextColor="White"
                                                 BackgroundColor="#E05A5A"
                                                 WidthRequest="42"
                                                 HeightRequest="42"
                                                 CornerRadius="21"
                                                 BorderWidth="0"
                                                 Clicked="OnDeleteItemClicked"
                                                 CommandParameter="{Binding}"
                                                 IsVisible="{Binding Source={x:Reference RootPage}, Path=IsDeleteMode}"
                                                 VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Row="2"
                             Spacing="16"
                             HorizontalOptions="Center"
                             Margin="0,18,0,0">
            <controls:AnimatedButton x:Name="AddListButton"
                                     Text="Add List"
                                     Clicked="OnAddListClicked"
                                     BackgroundColor="#E7F7EB"
                                     BorderColor="#91C2A1"
                                     Style="{StaticResource PillButtonStyle}" />

            <controls:AnimatedButton x:Name="DeleteListButton"
                                     Text="Delete List"
                                     Clicked="OnEnterDeleteModeClicked"
                                     Style="{StaticResource PillButtonStyle}" />

            <controls:AnimatedButton x:Name="CancelDeleteButton"
                                     Text="Cancel"
                                     Clicked="OnCancelDeleteModeClicked"
                                     Style="{StaticResource PillButtonStyle}"
                                     IsVisible="False" />
        </VerticalStackLayout>
    </Grid>

</ContentPage>
