<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="FreshTrack.ListManagementPage"
             x:Name="RootPage"
             Title="List Management">

    <ContentPage.Background>
        <SolidColorBrush Color="#DFF4E9" />
    </ContentPage.Background>

    <Border Stroke="#2E7D32" StrokeThickness="2" Padding="16">
        <Border.Resources>
            <ResourceDictionary>
                <Style x:Key="PillButtonStyle" TargetType="Button">
                    <Setter Property="WidthRequest" Value="220" />
                    <Setter Property="HeightRequest" Value="56" />
                    <Setter Property="CornerRadius" Value="28" />
                    <Setter Property="BackgroundColor" Value="#FFFFFF" />
                    <Setter Property="BorderColor" Value="#2E7D32" />
                    <Setter Property="BorderWidth" Value="2" />
                    <Setter Property="FontAttributes" Value="Bold" />
                    <Setter Property="HorizontalOptions" Value="Center" />
                    <Setter Property="Padding" Value="12,6" />
                    <Setter Property="TextColor" Value="#000000" />
                </Style>
            </ResourceDictionary>
        </Border.Resources>
        <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*">

            <Label Grid.Row="0" Text="List Management" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,6" />

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Spacing="18" HorizontalOptions="Center" VerticalOptions="Center">
                    <CollectionView x:Name="ListcollectionView" ItemsSource="{Binding Lists}" SelectionMode="None" ItemsLayout="VerticalList">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Grid ColumnDefinitions="Auto,Auto" VerticalOptions="Center" HorizontalOptions="Center">
                                        <Grid Column="0">
                                            <Grid WidthRequest="200" HeightRequest="80">
                                                <shapes:Ellipse Stroke="Black" StrokeThickness="2" Fill="Transparent" />
                                                <Label Text="{Binding Name}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       FontSize="18"
                                                       FontAttributes="Bold" />
                                                <!-- transparent overlay to capture clicks on the ellipse -->
                                                <Button BackgroundColor="Transparent"
                                                        BorderColor="Transparent"
                                                        Opacity="0"
                                                        Clicked="OnListClicked"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </Grid>

                                        <!-- delete X button on the right, visible only in delete mode -->
                                        <Button Grid.Column="1"
                                                Text="✕"
                                                FontSize="18"
                                                FontAttributes="Bold"
                                                TextColor="White"
                                                BackgroundColor="#E53E3E"
                                                WidthRequest="40"
                                                HeightRequest="40"
                                                CornerRadius="20"
                                                BorderWidth="0"
                                                Clicked="OnDeleteItemClicked"
                                                CommandParameter="{Binding}"
                                                IsVisible="{Binding Source={x:Reference RootPage}, Path=IsDeleteMode}"
                                                VerticalOptions="Center"
                                                Margin="8,0,0,0" />
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

            <VerticalStackLayout Grid.Row="2" Spacing="18" HorizontalOptions="Center" Margin="0,12">

                <!-- Simple pill-shaped Add List button (uses shared PillButtonStyle) -->
                <Button x:Name="AddListButton"
                        Text="Add List"
                        Clicked="OnAddListClicked"
                        Style="{StaticResource PillButtonStyle}" />

                <!-- Simple pill-shaped Delete List button -->
                <Button x:Name="DeleteListButton"
                        Text="Delete List"
                        Clicked="OnEnterDeleteModeClicked"
                        Style="{StaticResource PillButtonStyle}" />
                <Button x:Name="CancelDeleteButton" Text="Cancel" Clicked="OnCancelDeleteModeClicked" Style="{StaticResource PillButtonStyle}" IsVisible="False" />

                <HorizontalStackLayout x:Name="DeletePanel" IsVisible="False" Spacing="12" HorizontalOptions="Center">
                    <Button Text="Confirm Delete" BackgroundColor="Red" TextColor="White" Clicked="OnConfirmDeleteClicked" WidthRequest="140"/>
                    <Button Text="Cancel" Clicked="OnCancelDeleteClicked" WidthRequest="140"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>

        </Grid>
    </Border>

</ContentPage>