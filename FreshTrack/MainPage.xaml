<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreshTrack.MainPage">
    
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F5F7FA" Offset="0.0" />
            <GradientStop Color="#E4E8F0" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <VerticalStackLayout
        VerticalOptions="Center" 
        HorizontalOptions="Center"
        Spacing="20"
        Padding="40">

        <Label
            Text="Fresh Track"
            FontSize="32" 
            FontAttributes="Bold"
            TextColor="#2D3748"
            HorizontalOptions="Center"/>

        <Button
            x:Name="StartButton"
            Text="开始使用" 
            FontSize="18"
            FontAttributes="Bold"
            BackgroundColor="#4299E1"
            TextColor="White"
            CornerRadius="12"
            WidthRequest="200"
            HeightRequest="50"
            Clicked="OnStartClicked"/>

        <Button
            x:Name="ExitButton"
            Text="开始使用" 
            FontSize="18"
            FontAttributes="Bold"
            BackgroundColor="#4299E1"
            TextColor="White"
            CornerRadius="12"
            WidthRequest="200"
            HeightRequest="50"
            Clicked="OnExitClicked"/>
        
    </VerticalStackLayout>
</ContentPage>
