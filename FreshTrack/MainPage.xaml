<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreshTrack.MainPage">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#ECFDF5" Offset="0.0" />
            <GradientStop Color="#D1FAE5" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <VerticalStackLayout
        VerticalOptions="Center" 
        HorizontalOptions="Center"
        Spacing="20"
        Padding="40">

        <Label
            Text="Fresh Track"
            FontSize="32" 
            FontAttributes="Bold"
            TextColor="#2D3748"
            HorizontalOptions="Center"/>

        <Button
            x:Name="StartButton"
            Text="Start" 
            FontSize="14"
            BackgroundColor="#10B981"
            TextColor="White"
            CornerRadius="40"
            WidthRequest="80"
            HeightRequest="80"
            Padding="0"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Clicked="OnStartClicked"/>

        <Button
            x:Name="ExitButton"
            Text="Exit" 
            FontSize="18"
            BackgroundColor="#FF0000"
            TextColor="White"
            CornerRadius="30"
            WidthRequest="60"
            HeightRequest="60"
            Padding="0"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Clicked="OnExitClicked"/>

    </VerticalStackLayout>
</ContentPage>