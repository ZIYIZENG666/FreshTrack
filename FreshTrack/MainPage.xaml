<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FreshTrack.MainPage"
             Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F4FCF5" Offset="0.0" />
            <GradientStop Color="#D9F0E0" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid Padding="28">
        <VerticalStackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="20"
                             MaximumWidthRequest="340">
            <Label Text="FreshTrack"
                   FontSize="40"
                   FontAttributes="Bold"
                   TextColor="#214634"
                   HorizontalTextAlignment="Center" />

            <Label Text="Welcome back. Tap below to open your grocery lists and reminders."
                   FontSize="17"
                   TextColor="#5A7866"
                   HorizontalTextAlignment="Center" />

            <Border Padding="8,12"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    HorizontalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnStartTapped" />
                </Border.GestureRecognizers>

                <Label Text="---Open Today's Lists---"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#B02C5A42"
                       HorizontalTextAlignment="Center" />
            </Border>

        </VerticalStackLayout>
    </Grid>
</ContentPage>
